{
  "name": "mastra",
  "displayName": "Mastra (Next.js + TypeScript)",
  "hint": "Mastra framework + React + TypeScript",
  "language": "typescript",
  "devCommand": "bun run dev",
  "port": 8765,
  "sharedFiles": {
    "system-prompt.md": "src/mastra/agents/system-prompt.md",
    "agent-playbook.md.hbs": "AGENT_PLAYBOOK.md",
    "nextjs-ui": ""
  },
  "dotfileRenames": {
    "_gitignore": ".gitignore",
    "_env.example": ".env.example"
  },
  "placeholders": {
    "package.json": {
      "field": "name",
      "format": "json"
    }
  },
  "install": [
    {
      "cmd": "bun",
      "args": ["install"],
      "label": "Installing dependencies"
    }
  ],
  "migrate": [
    {
      "cmd": "bunx",
      "args": ["drizzle-kit", "generate"],
      "label": "Generating migrations"
    },
    {
      "cmd": "bunx",
      "args": ["drizzle-kit", "migrate"],
      "label": "Running migrations"
    }
  ]
}
